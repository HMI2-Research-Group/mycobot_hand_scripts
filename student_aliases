function backup_agx() {
  # Usage:
  #   backup_agx agx47 my_folder_name
  #   backup_agx             # -> error (needs folder)
  #   backup_agx agx47       # -> error (needs folder)

  local host="$1"
  local folder="$2"

  if [ -z "$host" ] || [ -z "$folder" ]; then
    echo "Usage: backup_agx <ssh_host> <remote_folder_name>"
    echo "Example: backup_agx agx47 my_folder_name"
    return 1
  fi

  local ts
  ts=$(date +%Y%m%d_%H%M%S)
  local outfile="${folder}_${host}_${ts}.tar.gz"

  echo "Backing up ${folder} from ${host}:~/agilex_ws/src to ./{$outfile} ..."
  ssh "$host" "cd ~/agilex_ws/src && tar czf - \"$folder\"" > "$outfile"
  }

  function push_agx() {
  # Usage: push_agx agx47 my_remote_folder
  local host="$1"
  local folder="$2"

  if [ -z "$host" ] || [ -z "$folder" ]; then
    echo "Usage: push_agx <ssh_host> <remote_folder_name>"
    echo "Example: push_agx agx47 my_folder_name"
    return 1
  fi

  echo "Deleting remote folder ~/agilex_ws/src/$folder on $host (if it exists)..."
  ssh "$host" "rm -rf ~/agilex_ws/src/$folder && mkdir -p ~/agilex_ws/src/$folder" || {
    echo "Remote cleanup/creation failed."
    return 1
  }

  echo "Syncing CURRENT LOCAL FOLDER -> $host:~/agilex_ws/src/$folder/"
  rsync -avz ./ "$host:~/agilex_ws/src/$folder/"
}

function check_scan() {
  if rostopic echo -n1 /scan >/dev/null 2>&1; then
    echo "messages are getting published to /scan. LIDAR is working."
  else
    echo "No messages detected on /scan. LIDAR is not working. Call the TA!"
  fi
}

function check_dabai() {
  if rostopic echo -n1 /camera/color/image_raw >/dev/null 2>&1; then
    echo "messages are getting published to RGB camera topic. RGB camera is working"
  else
    echo "No messages detected on RGB camera topic. RGB camera is not working. Call the TA!"
  fi
  if rostopic echo -n1 /camera/depth/image_raw >/dev/null 2>&1; then
    echo "messages are getting published to Depth camera topic. Depth camera is working"
  else
    echo "No messages detected on Depth camera topic. Depth camera is not working. Call the TA!"
  fi
}

function wiggle_1s() {
  omega_z=$1
  if [ -z "$omega_z" ]; then
    echo "Usage: wiggle_1s <angular_z>"
    return 1
  fi

  end=$((SECONDS + 1))
  while [ $SECONDS -lt $end ]; do
    rostopic pub -1 /cmd_vel geometry_msgs/Twist \
      "linear:  {x: 0.0, y: 0.0, z: 0.0}" \
      "angular: {x: 0.0, y: 0.0, z: $omega_z}"
    sleep 0.05
  done
}


function check_teleop() {
  echo "=============================================="
  echo " TELEOP SAFETY CHECK"
  echo "=============================================="
  echo "1) Place the robot ON THE GROUND (not on a table)."
  echo "2) Make sure there is some free space around it."
  echo "3) This test will only rotate the robot in place (no linear motion)."
  echo
  read -p "If everything is safe, press ENTER to start the wiggle test (Ctrl+C to cancel) " _

  # Small in-place wiggle: left, right, then stop

  # Turn a bit left
  wiggle_1s(0.5)
  # Turn a bit right
  wiggle_1s(-0.5)
  # Stop
  wiggle_1s(0.0)
  echo "Wiggle test complete. Robot should now be stopped. If it didn't move, please call the TA!"
}

